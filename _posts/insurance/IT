proc sql;
    create table miso_exposure_agg_by_state as
    select
        YEAR,
        ST,
		bg2_terr,
        county,
        countyfips,
        ZIPCD, 
        COV,
        SUB,

        sum(EARNED_PREMIUM)  as EARNED_PREMIUM,
        sum(EARNED_EXPOSURE) as EARNED_EXPOSURE

    from work.iso_exposure  


    group by
        YEAR,
        ST,
		bg2_terr,
        county,
        countyfips,
        ZIPCD, 
        COV,
        SUB,
;
